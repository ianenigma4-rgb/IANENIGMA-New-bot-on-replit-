# ── REQUIRED ───────────────────────────────────────────────────────────────

# Your WhatsApp number in full international format (no + or spaces)
PHONE_NUMBER=256775063416

# Owner number — who can use owner-only commands (defaults to PHONE_NUMBER)
OWNER_NUMBER=256775063416

# ── SESSION (for hosting panels / Katabump) ─────────────────────────────────
# Get your SESSION_ID from the knight-bot pairing site:
#   https://knight-bot-paircode.onrender.com
# 1. Enter your phone number on that site
# 2. Approve the pairing code on WhatsApp
# 3. Copy the entire base64 string it gives you
# 4. Paste it here as SESSION_ID
# When SESSION_ID is set the bot starts immediately without pairing every time.
SESSION_ID=

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Keep-alive server port (hosting panels usually set PORT automatically)
PORT=3000
