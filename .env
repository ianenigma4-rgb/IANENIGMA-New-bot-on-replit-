# ╔══════════════════════════════════════════════════════════╗
# ║         IANENIGMA MD BOT — Configuration File           ║
# ║  Edit the values below, then restart the bot.           ║
# ╚══════════════════════════════════════════════════════════╝

# ── Bot Phone Number ──────────────────────────────────────────
# Your WhatsApp number WITHOUT + or spaces  (international format)
PHONE_NUMBER=256775063416

# ── Owner / Admin Number ──────────────────────────────────────
# Same number as above (owner who receives alerts, antidelete, etc.)
OWNER_NUMBER=256775063416

# ── Session ID ───────────────────────────────────────────────
# Get this from: https://knight-bot-paircode.onrender.com
# Paste the FULL string exactly as given (including any prefix like IANENIGMA;;;...)
# Leave blank if you are placing creds.json directly in the session/ folder
SESSION_ID=

# ── Bot Mode ──────────────────────────────────────────────────
# public  = anyone can use the bot
# private = only owner can use the bot
BOT_MODE=public

# ── Web Server Port ───────────────────────────────────────────
# Leave as 3000 unless your host panel requires a different port
PORT=3000
